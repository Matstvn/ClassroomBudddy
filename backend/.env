# backend/.env
APP_NAME="Teacher Classroom Companion"
ENVIRONMENT="development"  # or "production"

# Database (PostgreSQL/MySQL/SQLite)
DATABASE_URL="mysql+pymysql://teacher:secure_password@localhost:3306/teacher_companion"

# JWT Authentication
SECRET_KEY="your-very-long-and-complex-secret-key-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Frontend URL)
CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173"]'